{
  "$schema": "node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["@qingshaner/eslint-config/biome"],
  "linter": {
    "rules": {
      "correctness": {
        "noUndeclaredDependencies": "off"
      },
      "nursery": {
        "useExplicitType": "warn"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts", "**/*.bench.ts"],
      "linter": {
        "rules": {
          "nursery": {
            "useExplicitType": "off"
          }
        }
      }
    },
    {
      "assist": {
        "actions": {
          "source": {
            "useSortedKeys": "off"
          }
        }
      },
      "includes": [".config/tsconfig.*.json", "tsconfig.json", "**/*/package.json", "package.json"]
    }
  ]
}
