{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",

    "lib": ["ESNext"],
    "rootDir": "..",
    "paths": {
      "@qingshaner/utility": ["../packages/utility/src"],
      "@qingshaner/utility-client": ["../packages/client/src"],
      "@qingshaner/utility-node": ["../packages/node/src"],
      "@qingshaner/utility-shared": ["../packages/shared/src"]
    },
    "types": ["node"]
  },
  "include": [
    "../packages/server/src",
    "../packages/shared/src",
    "../packages/utility/src/server.ts",
    "../packages/utility/src/index.ts",
    "../**/*/*.config.ts",
    "./*.ts",
    "../scripts",
    "../vitest.config.ts"
  ]
}
