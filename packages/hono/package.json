{
  "name": "@qingshaner/utility-hono",
  "type": "module",
  "version": "0.1.0",
  "author": {
    "name": "qingshaner",
    "url": "https://github.com/Jon-a-than"
  },
  "license": "ISC",
  "keywords": [
    "utility",
    "hono",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tsingshaner/utility.git"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./middlewares": {
      "types": "./dist/middlewares.d.mts",
      "import": "./dist/middlewares.mjs",
      "default": "./dist/middlewares.mjs"
    }
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@logtape/logtape": ">=2.1.5 <3",
    "hono": "^4.0.0",
    "typescript": ">=6.0.3",
    "valibot": ">= 1.4.0 <2"
  },
  "peerDependenciesMeta": {
    "@logtape/logtape": {
      "optional": true
    },
    "hono": {
      "optional": false
    },
    "typescript": {
      "optional": true
    },
    "valibot": {
      "optional": false
    }
  },
  "dependencies": {
    "@hono/standard-validator": "^0.3.0",
    "@standard-schema/spec": "^1.1.0"
  }
}
