{
  "name": "@qingshaner/utility",
  "type": "module",
  "version": "1.0.2",
  "description": "Some utilities for JavaScript & TypeScript projects",
  "author": {
    "name": "qingshaner",
    "url": "https://github.com/Jon-a-than"
  },
  "license": "ISC",
  "sideEffects": false,
  "keywords": [
    "utility",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tsingshaner/utility.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "import": "./dist/server.mjs",
      "default": "./dist/server.mjs"
    },
    "./client": {
      "types": "./dist/client.d.mts",
      "import": "./dist/client.mjs",
      "default": "./dist/client.mjs"
    }
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "typescript": ">=6.0.3"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "@qingshaner/utility-client": "workspace:*",
    "@qingshaner/utility-server": "workspace:*",
    "@qingshaner/utility-shared": "workspace:*"
  }
}
