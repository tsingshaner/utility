{
  "name": "utility",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "description": "Some utilities for JavaScript & TypeScript projects",
  "author": {
    "name": "qingshaner",
    "url": "https://github.com/Jon-a-than"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tsingshaner/utility.git"
  },
  "license": "ISC",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "changeset-version": "changeset version && pnpx @qingshaner/jsr-release version --allowDirty --sync",
    "changeset-publish": "changeset publish",
    "format": "biome format . --write",
    "lint": "biome lint . --write && eslint . --fix",
    "prepare": "simple-git-hooks",
    "test": "vitest run",
    "test:cov": "vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@changesets/cli": "^2.31.0",
    "@qingshaner/eslint-config": "^2.0.0",
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "lint-staged": "^17.0.8",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.8",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "pre-push": "pnpm test"
  },
  "lint-staged": {
    "*.{vue,js,jsx,cjs,mjs,ts,tsx,cts,mts}": [
      "pnpm biome lint --write",
      "pnpm eslint --cache --fix"
    ],
    "*.{js,jsx,cjs,mjs,ts,tsx,cts,mts}": "pnpm biome format --write"
  }
}
